# ═══════════════════════════════════════════════════════════════════
# EcoGuide AI — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────
# Public URL of the application (used for OG meta tags and canonical URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───────────────────────────────────────────────────────
# Required for real auth, database, and file storage.
# Leave empty to use in-memory mock mode (no Supabase account needed).
# Get your values from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (never expose this in the browser)
# Required for admin operations (leaderboard refresh, RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic AI ───────────────────────────────────────────────────
# Required for the AI Sustainability Coach feature.
# Get your key from: https://console.anthropic.com/api-keys
# Server-side only — never expose this in the browser.
ANTHROPIC_API_KEY=
